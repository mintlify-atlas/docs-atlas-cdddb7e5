  "keyFeatures": [
    "Automatic bi-directional sync between local SQL Server and Digible cloud",
    "Real-time change tracking using database triggers",
    "Desktop GUI for easy configuration and monitoring",
    "Batch product upload with configurable batch sizes",
    "Support for Windows Authentication and SQL Server authentication",
    "Scheduled sync tasks with manual sync override"
  ],
  "publicApiSurface": [
    "sync_data(db_url) - Main synchronization function",
    "digible_connect(username, password) - Authenticate with Digible API",
    "createConnectionString(server_name, database_name, username, password, security) - Generate SQL Server connection string",
    "create_change_log_and_triggers(db_url) - Setup change tracking infrastructure",
    "sendBatchContent() - Upload all products in batches",
    "test_connectionString(db_url) - Test database connection",
    "uploadInsertedContent(product) - Upload single product",
    "updateProduct(product) - Update existing product"
  ]
